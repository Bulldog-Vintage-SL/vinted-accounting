# Local development only — copy to .env.local
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Production — set these in the Vercel dashboard (NOT localhost):
# NEXTAUTH_URL=https://vintflow.com
# NEXT_PUBLIC_APP_URL=https://vintflow.com
# AUTH_SECRET=<same value as NEXTAUTH_SECRET>
# AUTH_TRUST_HOST=true

GOOGLE_ID=
GOOGLE_SECRET=
