# Local development only — copy to .env.local
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_secret
AUTH_SECRET=generate_a_random_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel (*.vercel.app deployment) — use YOUR deployment URL:
# NEXTAUTH_URL=https://vinted-accounting-sigma.vercel.app
# NEXT_PUBLIC_APP_URL=https://vinted-accounting-sigma.vercel.app
# AUTH_TRUST_HOST=true
#
# Google OAuth (add for each deployed URL):
# https://vinted-accounting-sigma.vercel.app/api/auth/callback/google
# https://vintflow.com/api/auth/callback/google
#
# Custom domain on Vercel (when vintflow.com is attached):
# AUTH_CANONICAL_URL=https://vintflow.com
# NEXTAUTH_URL=https://vintflow.com
# NEXT_PUBLIC_APP_URL=https://vintflow.com

GOOGLE_ID=
GOOGLE_SECRET=
MONGODB_URI=
RESEND_API_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_EXTENSION_ID=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=
